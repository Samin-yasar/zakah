# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# See: https://editorconfig.org

root = true

# Universal settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript files
[*.{js,json,html,css}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# YAML/GitHub workflow files
[*.{yml,yaml}]
indent_style = space
indent_size = 2
