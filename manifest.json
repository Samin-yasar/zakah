{
  "name": "Zakah Calculator",
  "short_name": "Zakah Calc",
  "description": "A comprehensive, scholarly-accurate Zakah calculator covering all asset categories including digital wallets, investments, and business assets.",
  "id": "com.saminyasar.zakahcalc",
  "start_url": "./index.html",
